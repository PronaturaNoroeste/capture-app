{
  "expo": {
    "name": "Monitoreo Pesquero",
    "slug": "capture-app",
    "version": "1.0.4",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.pronatura.captura"
    },
    "android": {
      "package": "org.pronatura.captura",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "note": "GMS-free: MapLibre/OSM + OS location; sideload/AppGallery; no FCM. expo-sqlite/expo-location autolink — no config plugin needed for M1.",
      "eas": {
        "projectId": "babdd633-f686-4757-9a9f-5155a569711b"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "owner": "pronatura050927"
  }
}
